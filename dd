def setup_logger():
    log_dir = get_logs_paths()
    log_dir.mkdir(exist_ok=True)

    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    log_file = log_dir / f"ZRPPM2010_{timestamp}.log"

    logger = logging.getLogger("SAP_ZRPPM2010")
    logger.setLevel(logging.DEBUG)

    # Formato
    fmt = logging.Formatter(
        "[%(asctime)s] [%(levelname)-8s] %(message)s",
        datefmt="%Y-%m-%d %H:%M:%S"
    )
     # Handler → archivo
    fh = logging.FileHandler(log_file, encoding="utf-8")
    fh.setLevel(logging.DEBUG)
    fh.setFormatter(fmt)

    # Handler → consola
    ch = logging.StreamHandler(sys.stdout)
    ch.setLevel(logging.INFO)
    ch.setFormatter(fmt)

    logger.addHandler(fh)
    logger.addHandler(ch)

    logger.info(f"Log started: {log_file}")
    return logger


def get_logs_paths():
    today = datetime.now().strftime("%y-%m-%d-logs")
    folder_name = f"logs_{today}"
    pathlogs = Path(BASE_LOG_DIR) / folder_name
    pathlogs.mkdir(parents=True, exist_ok=True)
    return pathlogs

def get_latest_file(directory, pattern="*"):
    """Busca el archivo más reciente en una carpeta con un patrón específico.
    
    Args:
        directory: Ruta de la carpeta donde buscar
        pattern: Patrón de nombre de archivo (ej: "Item Qty_*")
    
    Returns:
        Path del archivo más reciente o None si no encuentra
    """
    directory = Path(directory)
    files = sorted(directory.glob(pattern), key=lambda p: p.stat().st_mtime, reverse=True)
    return files[0] if files else None

def wait_element(session, element, timeout=15):
    start = time.time()
    while time.time() - start < timeout:
        try:
            return session.findById(element)
        except:
            time.sleep(1)
    raise Exception(f"Element not found: {element}")

def calculate_date():
    today = datetime.now()
    first_day_of_month = today.replace(day=1)
    yesterday = today - timedelta(days=1)
    return first_day_of_month.strftime("%Y.%m.%d"), yesterday.strftime("%Y.%m.%d")

log = setup_logger()


def open_sap():
    
    try:
        log.info("[LOG] Opening SAP Logon...")
        os.system("taskkill /f /im saplogon.exe >nul 2>&1")
        time.sleep(2)
        subprocess.Popen(r"C:\Program Files (x86)\SAP\FrontEnd\SAPgui\saplogon.exe")

        time.sleep(5)
        # Abrir SAP Logon
        sap_gui = win32com.client.GetObject("SAPGUI")
        application = sap_gui.GetScriptingEngine

        # Conexión (0 = primera conexión)
        connection = application.OpenConnection(server, True)

        time.sleep(3)

        # Crear sesión
        session = connection.Children(0)

        # Esperar campos login
        wait_element(session, "wnd[0]/usr/txtRSYST-BNAME")
        log.info("[LOG] Performing Login...")
        # Credenciales
        session.findById("wnd[0]").maximize()        
        session.findById("wnd[0]/usr/txtRSYST-BNAME").setFocus()
        session.findById("wnd[0]/usr/txtRSYST-BNAME").text = user
        session.findById("wnd[0]/usr/pwdRSYST-BCODE").text = password
        # Enter
        session.findById("wnd[0]").sendVKey(0)

        return session

    except Exception as e:
        log.error("Error opening SAP: %s", e)

def open_main_excel():
    ksi_file = os.getenv("KSI_MONITORING_FILE")
    try:
        wb = load_workbook(ksi_file)
        log.info("Main Excel file opened successfully")
        return wb, ksi_file
    except Exception as e:
        log.error(f"Error opening Main Excel file: {e}")
        sys.exit(1)

def paste_to_sheet(wb, sheet_name, clipboard_data, start_row, start_col):
    parsed = [row.split('\t') for row in clipboard_data.splitlines() if row.strip()]
    ws = wb[sheet_name]
    for r_idx, row in enumerate(parsed, start=start_row):
        for c_idx, value in enumerate(row, start=start_col):
            ws.cell(row=r_idx, column=c_idx, value=value)
    log.info(f"Data pasted to sheet '{sheet_name}' ({len(parsed)} rows)")

