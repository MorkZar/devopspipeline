def searchAndDownload(driver):
    # ── 6. Ejecutar búsqueda ──────────────────────────────────────────────
    wait_frame = WebDriverWait(driver, 20)
    log.info("Excecuting main search...")
    wait_frame.until(EC.element_to_be_clickable((By.ID, "btnMainSearch"))).click()
    log.info("Búsqueda iniciada")

    # ── 7. Esperar resultados ─────────────────────────────────────────────
    log.info("Waiting for loading bar...")
    WebDriverWait(driver, 20).until(
        EC.invisibility_of_element_located((By.ID, "loadingBar"))
    )
    log.info("Results loaded")

    # ── 8. Descargar Excel ────────────────────────────────────────────────
    log.info("Starting Excel Download...")
    download_btn = WebDriverWait(driver, 10).until(
    EC.element_to_be_clickable((By.ID, "btnGrid3ExcelDownload"))
    )
    download_btn.click()
    log.debug("Excel download button clicked")

    time.sleep(5)
    driver.switch_to.active_element.send_keys(Keys.ENTER)
    log.info("Download confirmation sent (ENTER)")
    time.sleep(10)

def process_excel(download_path):
    log.info("Looking for latest Excel file...")
    latest_excel = get_latest_file(download_path, "Location Item Qty_*.xlsx")
    if latest_excel:
        log.info(f"Opening latest file: {latest_excel.name}")
        wb1 = load_workbook(latest_excel)
        ws = wb1.active
        
        # ── Desproteger workbook si está protegido ──────────────────────
        if wb1.read_only:
           log.info("Workbook structure is locked. Unlocking...")
           wb1.security.read_only = False
           log.info("Workbook unlocked successfully")
        
    else:
      log.error("No file found")
      sys.exit(1)

    #print('Total number of rows: '+str(ws.max_row)+'. And total number of columns: '+str(ws.max_column))

    log.info("Cleaning up Excel file...")
    ws.delete_rows(1, 2)   # Delete Row 1 and 2
    time.sleep(1)          
    ws.delete_rows(ws.max_row, 1) #Delete Total Row
    time.sleep(1)
    log.info("Excel file cleaned")

    log.info("Copying data...")
    # Copiar todo
    data = []
    for row in ws.iter_rows(values_only=True):
       data.append(row)
    time.sleep(2)
    wb1.close()


    wb2 = None
    log.info("Opening Main Excel file...")
    try:
      mcm_qc= os.getenv("MCM_QC_INV_MONITORING_FILE")
      wb2 = load_workbook(mcm_qc)
      ws = wb2.active
      # trabajar
      ws_target = wb2["Inv.All_Loc"]          # hoja destino

      # Pegar desde A2ttd
      start_row = 3
      start_col = 2
      for r_idx, row in enumerate(data, start=start_row):
        for c_idx, value in enumerate(row, start=start_col):
            ws_target.cell(row=r_idx, column=c_idx, value=value)
      log.info("Data copied to target workbook")
      wb2.save(mcm_qc)

    except Exception as e:
      print(f"Error: {e}")

    finally:
     if wb2:
        wb2.close()

def processPV3():
    file = os.getenv("MCM_QC_INV_MONITORING_FILE")
    if not file:
        log.error("Variable MCM_QC_INV_MONITORING_FILE not found in .env")
        return

    excel = win32com.client.Dispatch("Excel.Application")
    excel.Visible = True
    excel.WindowState = -4137  # xlMaximized
    wb = excel.Workbooks.Open(file)
    ws = wb.Sheets("PV3 (QC)")
    time.sleep(5)

    ws.Activate()
    ws.Cells(5, 11).Select()
    # Abre la pestaña contextual "PivotTable Analyze" en la cinta.
    
    log.info("Workbook saved after PV3 processing")

