def main():
    driver = None

    try:
        # ── Validar credenciales ──────────────────────────────────────────────
        if not USUARIO or not PASSWORD:
            log.error("Variables GMES_USER / GMES_PASS not found in file .env")
            sys.exit(1)
        log.info(f"User loaded: {USUARIO}")

        if not URL:
            log.error("Variable URL_GMES not found in file .env")
            sys.exit(1)

        # ── Preparar carpeta de descarga ──────────────────────────────────────
        download_path = get_download_path()
        log.info(f"Download folder: {download_path}")

        # ── Chrome Options────────────────────────────────────────────────
        log.info("Configuring Chrome...")
        chrome_options = Options()
        chrome_options.add_argument("--start-maximized")
        chrome_options.add_argument("--disable-notifications")
        #chrome_options.add_argument("--disable-hang-monitor")
        #chrome_options.add_argument("--disable-dev-shm-usage")
        #chrome_options.add_argument("--no-sandbox")
        #chrome_options.add_argument("--headless=new")
        #chrome_options.add_argument("--disable-gpu")
        chrome_options.add_experimental_option("prefs", {
            "download.default_directory": str(download_path),
            "download.prompt_for_download": False,
            "directory_upgrade": True,
        })

        # ── Inicializar driver ────────────────────────────────────────────────
        log.info("Starting ChromeDriver...")
        driver = webdriver.Chrome(
            service=Service(ChromeDriverManager().install()),
            options=chrome_options
        )
        driver.set_page_load_timeout(600)
        driver.set_script_timeout(600)

        wait = WebDriverWait(driver, 20)
        log.info("ChromeDriver started succesfully")

        #Login
        login(driver)
        #Navegación por menú
        navigate_menu(driver)
        #Búsqueda y descarga de Excel
        searchAndDownload(driver)
        time.sleep(3)
    
    except TimeoutException as e:
        log.error(f"Timeout waiting for element: {e}")
        sys.exit(2)
    except WebDriverException as e:
        log.error(f"WebDriver error: {e}")
        sys.exit(3)
    except Exception as e:
        log.exception(f"Unexpected error: {e}")
        sys.exit(4)
    finally:
        if driver:
            log.info("Closing browser...")
            driver.quit()
            log.info("Browser Closed")
    log.info("✅ Continue with excel processing...")
    process_excel(download_path)
    processPV3()
    time.sleep(3)
    log.info("Automation finished successfully")

if __name__ == "__main__":
    main()
