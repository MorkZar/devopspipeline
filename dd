def process_ZRPPS1000(session, wb, first_day_of_month, last_day_of_month):
    log.info("[LOG] Starting SAP data extraction process from ZRPPS1000...")
    # Maximizar
    session.findById("wnd[0]").maximize()
    # Transacción
    session.findById("wnd[0]/tbar[0]/okcd").text = "ZRPPS1000"
    session.findById("wnd[0]").sendVKey(0)
    session.findById("wnd[0]/usr/ctxtS_WERKS-LOW").text = "3301"
    session.findById("wnd[0]/usr/ctxtS_DATUM-LOW").text = first_day_of_month
    session.findById("wnd[0]/usr/ctxtS_DATUM-HIGH").text = last_day_of_month
    session.findById("wnd[0]/usr/ctxtS_DATUM-HIGH").setFocus()
    session.findById("wnd[0]/usr/ctxtS_DATUM-HIGH").caretPosition = 10
    log.info("Waiting for data to load in SAP...")
    session.findById("wnd[0]/tbar[1]/btn[8]").press()
    
    summary_shell = session.findById("wnd[0]/shellcont/shell")

    def _get_detail_shell(timeout=10):
        candidates = [
            "wnd[0]/shellcont/shell[0]",
            "wnd[0]/usr/cntlCC_0100/shellcont/shell",
            "wnd[0]/usr/shellcont/shell",
        ]
        start = time.time()
        while time.time() - start < timeout:
            for element_id in candidates:
                try:
                    return session.findById(element_id)
                except:
                    continue
            time.sleep(0.3)
        raise Exception("Detail grid not found after drill-down")
    

    summary_shell.setCurrentCell(3, "ZPRERROR_CNT")
    cell_value = summary_shell.getCellValue(3, "ZPRERROR_CNT")
    cell_value_str = str(cell_value).strip() if cell_value is not None else ""

    if cell_value_str and cell_value_str != "0":
        log.info(f"Celda 3 contiene: {cell_value_str}, procediendo...")
        summary_shell.clickCurrentCell()
        session.findById("wnd[0]/shellcont/shell").setCurrentCell(-1,"")
        session.findById("wnd[0]/shellcont/shell").selectAll()
        session.findById("wnd[0]/shellcont/shell").setFocus()
        pyautogui.hotkey('ctrl', 'c')
        data2 = pyperclip.paste()
        log.info("Data copied from SAP clipboard")
        paste_to_sheet(wb, "12.04", data2, 2, 3)
        session.findById("wnd[0]/tbar[0]/btn[15]").press()
    else:
        log.info("Celda 3 vacia o en 0, omitiendo proceso.")
    ############################################
    summary_shell.setCurrentCell(4, "ZPRERROR_CNT")
    cell_value = summary_shell.getCellValue(4, "ZPRERROR_CNT")
    cell_value_str = str(cell_value).strip() if cell_value is not None else ""

    if cell_value_str and cell_value_str != "0":
        log.info(f"Celda 4 contiene: {cell_value_str}, procediendo...")
        summary_shell.clickCurrentCell()
        time.sleep(1)
        erroes_shell = _get_detail_shell()
        real_rows = erroes_shell.rowCount
        print(f"Real row count in detail grid: {real_rows}")
        if real_rows == 1:
           time.sleep(0.5)
           session.findById("wnd[0]/shellcont/shell[0]").selectedRows = "0"
           session.findById("wnd[0]/shellcont/shell").setFocus()
           pyautogui.hotkey('ctrl', 'c')
           data3 = pyperclip.paste()
           log.info("Data copied from SAP clipboard")
           paste_to_sheet(wb, "12.05", data3, 2, 4)
        else:
           session.findById("wnd[0]/shellcont/shell").selectAll()
           session.findById("wnd[0]/shellcont/shell").setFocus()
           pyautogui.hotkey('ctrl', 'c')
           data3 = pyperclip.paste()
           log.info("Data copied from SAP clipboard")
           paste_to_sheet(wb, "12.05", data3, 2, 4)
           
        session.findById("wnd[0]/tbar[0]/btn[15]").press()
    else:
        log.info("Celda 4 vacia o en 0, omitiendo proceso.")
        
    log.info("ZRPPM1000 process completed.")


def main():
    session = open_sap()
    log.info("Opening main Excel file...")
    wb, ksi_file = open_main_excel()
    try:
        #item_error(session, wb)
        #bom_error(session,  wb)
        first_day_of_month, yesterday = calculate_date()
        process_ZRPPS1000(session, wb, first_day_of_month, yesterday)
        wb.save(ksi_file)
        log.info(f"Workbook saved: {ksi_file}")
    except Exception as e:
        log.error(f"Error in main: {e}")
    finally:
        wb.close()
        log.info("Workbook closed.")
    

if __name__ == "__main__":
    main()   
