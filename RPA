    for row in ws1.iter_rows(values_only=True):
       data1.append(row)
    time.sleep(15)
    wb2.close()


    wb3 = None
    log.info("Opening ...")
    try:
      ksi_file= os.getenv("KSI_MONITORING_FILE")
      wb3 = load_workbook(ksi_file)
      ws = wb3.active
      # trabajar on sheet "RM Defect"
      ws_target = wb3["RM Defect"]    

      # Pegar desde C3
      start_row = 3
      srtart_col = 3
      for r_idx, row in enumerate(data1, start=start_row):
        for c_idx, value in enumerate(row, start=srtart_col):
            ws_target.cell(row=r_idx, column=c_idx, value=value)
      log.info("Data copied to target workbook")
      wb3.save(ksi_file)
      log.info(f"Workbook saved: {ksi_file}")

    except Exception as e:
      print(f"Error: {e}")

    finally:
     if wb3:
        wb3.close()

    log.info("✅ Automation finished succesfully")

